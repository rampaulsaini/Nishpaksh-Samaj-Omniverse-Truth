// COSMOS — Green tech stars
(function(){
  const c=document.getElementById('cosmos'),ctx=c.getContext('2d');let w,h,stars=[];
  function resize(){w=c.width=window.innerWidth;h=c.height=window.innerHeight;
    stars=[];for(let i=0;i<200;i++)stars.push({x:Math.random()*w,y:Math.random()*h,
      r:Math.random()<.6?.4:Math.random()<.85?1:1.5,a:Math.random(),
      da:.002+Math.random()*.007,hue:Math.random()<.7?90:Math.random()<.5?120:60});}
  function draw(){ctx.clearRect(0,0,w,h);
    stars.forEach(s=>{s.a+=s.da;if(s.a>1||s.a<.05)s.da*=-1;
      ctx.beginPath();ctx.arc(s.x,s.y,s.r,0,Math.PI*2);
      ctx.fillStyle=`hsla(${s.hue},80%,60%,${s.a*.6})`;ctx.fill();});
    requestAnimationFrame(draw);}
  window.addEventListener('resize',resize);resize();draw();
})();

